DISCORD_TOKEN=your_bot_token_here
DISCORD_CLIENT_ID=your_client_id_here
DISCORD_CLIENT_SECRET=your_client_secret_here
DATABASE_URL="postgresql://adepetbot:password@localhost:5432/adepetbot?schema=public"

# Web/API
WEB_PORT=3000
# Render sets PORT automatically. WEB_PORT is only for local development.
WEB_BASE_URL=http://localhost:3000
SESSION_SECRET=change_me_to_random_string
SESSION_TTL=86400
LOG_LEVEL=info
LOG_PRETTY=true
REDIS_URL=

# Vote sistemi
# VOTE_URL icinde {userId} ve {returnUrl} placeholder kullanilabilir.
VOTE_URL=https://example.com/vote?user={userId}&return={returnUrl}
VOTE_SOURCE=web
VOTE_WEBHOOK_SECRET=change_me_vote_secret
VOTE_MANUAL_CONFIRM=0
VOTE_COOLDOWN_HOURS=24
VOTE_REWARD_GOLD=750
VOTE_REWARD_GEM=1
